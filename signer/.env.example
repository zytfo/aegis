# Pi Signer daemon config
PORT=8787
# REQUIRED. The daemon refuses to start if SIGNER_TOKEN is unset or left as a
# known dev default (e.g. "change-me", "change-me-to-a-long-random-string").
SIGNER_TOKEN=change-me-to-a-long-random-string

# Casper testnet (live GuardedWallet)
NODE_ADDRESS=https://node.testnet.casper.network
CHAIN_NAME=casper-test
CONTRACT_PACKAGE_HASH=hash-1359b30133125889599ba0127868f83c06820677341e5eafa70eba49c0fe7bb3
PAYEE_HASH=account-hash-fed4d31a4c43bd2e527df1dbf01abf3ace959dda2ce712e45b327b608095e54a

# Policy
PER_TX_MAX_MOTES=5000000000      # 5 CSPR per-tx cap (period_cap enforced on-chain)

# Gas (hardcoded server-side; brain never supplies gas). pay() consumes ~3.15 CSPR;
# 3 CSPR was Out-of-gas, so default 5 CSPR gives headroom above the 2.5 CSPR minimum.
PAY_GAS_MOTES=5000000000

# Encrypted-at-rest device key store
DEVICE_PEM_PATH=keys/device/secret_key.pem
KEY_STORE_PATH=./device.enc
# REQUIRED. The daemon refuses to start if KEY_PASS is unset or a dev default.
KEY_PASS=change-me

# Replay + audit state
SEQ_PATH=./seq.txt
AUDIT_PATH=./audit.jsonl
